DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Security
APP_ENCRYPTION_SECRET="replace-with-a-long-random-secret"
WAITLIST_ADMIN_TOKEN="replace-with-a-long-random-admin-token"

# Site-wide access gate (pre-launch soft-lock). Defaults to "ANSHIT" if unset — see middleware.ts.
SITE_ACCESS_CODE="ANSHIT"

# Launch timing / WebXP
WAITLIST_LAUNCH_AT="2026-07-08T00:00:00.000Z"

# Email delivery. Use either Resend or a custom webhook.
RESEND_API_KEY=""
WAITLIST_FROM_EMAIL="Webcoin Labs <waitlist@your-domain.com>"
SIGNUP_FROM_EMAIL=""
WAITLIST_EMAIL_WEBHOOK_URL=""
WAITLIST_EMAIL_WEBHOOK_TOKEN=""

# Operational monitoring. Receives sanitized JSON for unhandled server
# errors, email-delivery failures, and blocked high-risk signup activity.
WAITLIST_ALERT_WEBHOOK_URL=""
WAITLIST_ALERT_WEBHOOK_TOKEN=""

# Signup abuse controls. Defaults are conservative for shared networks.
WAITLIST_MAX_SIGNUPS_PER_IP_HOUR="10"
WAITLIST_MAX_SIGNUPS_PER_IP_DAY="25"
WAITLIST_MAX_SIGNUPS_PER_DEVICE_DAY="4"
WAITLIST_MAX_SIGNUPS_PER_IP_DOMAIN_DAY="6"
WAITLIST_MAX_SIGNUPS_PER_DEVICE_DOMAIN_DAY="3"

# Optional comma-separated additions to the built-in disposable-domain list.
WAITLIST_DISPOSABLE_EMAIL_DOMAINS=""
